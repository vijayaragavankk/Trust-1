# .env.example  – copy to .env and fill in your real Firebase values
# NEVER commit the real .env file. Add .env to .gitignore.
#
# For Vercel: paste each key into Project → Settings → Environment Variables
# making sure to select all three environments (Production / Preview / Development).

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Razorpay (only publishable key goes here – never the secret key)
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
